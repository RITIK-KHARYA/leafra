# Copy this file to .env.local and fill in the values.
# Only the variables marked "REQUIRED" are needed for `npm run dev` to boot.
# The rest are feature-gated: missing them only breaks the specific feature.

# -------- REQUIRED (app refuses to start without these) --------
DATABASE_URL=postgres://user:password@host:5432/leafra

# -------- FEATURE-GATED (optional at boot, required per-feature) --------
# Gemini AI key for chat streaming (gemini-2.5-flash).
# Powers: app/api/chat/route.ts
GEMINI_AI_API_KEY=

# SuperMemory API key for RAG pipeline (document storage, embeddings, search).
# Powers: lib/integrations/supermemory.ts, app/api/uploadthing/core.ts
SUPERMEMORY_API_KEY=

# -------- OPTIONAL (Redis / rate limiting) --------
# Upstash REST for rate-limiter only.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# -------- OPTIONAL (OAuth social providers) --------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# -------- OPTIONAL (public site URL for better-auth callbacks) --------
# Defaults to http://localhost:3000 in dev, production URL in prod.
NEXT_PUBLIC_BASE_URL=

# -------- OPTIONAL (UploadThing, if used) --------
UPLOADTHING_TOKEN=
