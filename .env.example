# Copy this file to .env.local and fill in the values.
# Only the variables marked "REQUIRED" are needed for `npm run dev` to boot.
# The rest are feature-gated: missing them only breaks the specific feature.

# -------- REQUIRED (app refuses to start without these) --------
DATABASE_URL=postgres://user:password@host:5432/leafra
PINECONE_API_KEY=your-pinecone-key

# -------- FEATURE-GATED (optional at boot, required per-feature) --------
# Single AI key for chat streaming, embeddings (ingestion + retrieval).
# Powers: app/api/chat/route.ts, lib/worker.ts, lib/integrations/pinecone.ts
GEMINI_AI_API_KEY=

# -------- OPTIONAL (Redis / rate limiting / queue) --------
# BullMQ (worker queue) requires a raw TCP URL (redis://host:port).
# Upstash REST (https://...) works only for the rate-limiter, NOT the queue.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# -------- OPTIONAL (OAuth social providers) --------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# -------- OPTIONAL (public site URL for better-auth callbacks) --------
# Defaults to http://localhost:3000 in dev, production URL in prod.
NEXT_PUBLIC_BASE_URL=

# -------- OPTIONAL (UploadThing, if used) --------
UPLOADTHING_TOKEN=
